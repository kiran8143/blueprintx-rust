# BlueprintX Rust Configuration
# Copy to .env and fill in your values: cp .env.example .env

# Server
PORT=8081
HOST=0.0.0.0
ENVIRONMENT=development

# Database
DB_ENGINE=postgresql          # postgresql | mysql | sqlite3
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=postgres
DB_PASSWORD=changeme
DB_POOL_SIZE=5
DB_FAST_MODE=true
DB_TIMEOUT=30.0

# Analytics Database (optional - leave DB_ANALYTICS_HOST empty to disable)
# DB_ANALYTICS_HOST=localhost
# DB_ANALYTICS_PORT=5432
# DB_ANALYTICS_ENGINE=postgresql
# DB_ANALYTICS_NAME=analytics
# DB_ANALYTICS_USER=postgres
# DB_ANALYTICS_PASSWORD=
# DB_ANALYTICS_POOL_SIZE=2
# DB_ANALYTICS_FAST_MODE=true
# DB_ANALYTICS_TIMEOUT=60.0

# JWT Authentication
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRY_SECONDS=3600

# Redis (L2 Cache - optional, leave REDIS_HOST empty to disable)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_SECS=60

# Logging
LOG_LEVEL=INFO                # TRACE | DEBUG | INFO | WARN | ERROR
